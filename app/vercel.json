{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai.js": {
      "maxDuration": 60
    },
    "api/inbound-email.js": {
      "maxDuration": 60
    },
    "api/import-rfp.js": {
      "maxDuration": 30
    },
    "api/retry-parse.js": {
      "maxDuration": 60
    },
    "api/nova-voice.js": {
      "maxDuration": 15
    },
    "api/blob.js": {
      "maxDuration": 30
    },
    "api/ocr.js": {
      "maxDuration": 30
    },
    "api/embed.js": {
      "maxDuration": 15
    },
    "api/vector-search.js": {
      "maxDuration": 15
    },
    "api/seed-embeddings.js": {
      "maxDuration": 120
    },
    "api/send-proposal.js": {
      "maxDuration": 15
    },
    "api/bid-package.js": {
      "maxDuration": 15
    },
    "api/send-bid-invite.js": {
      "maxDuration": 15
    },
    "api/portal.js": {
      "maxDuration": 15
    },
    "api/portal-upload.js": {
      "maxDuration": 15
    },
    "api/portal-confirm.js": {
      "maxDuration": 30
    },
    "api/parse-proposal.js": {
      "maxDuration": 60
    },
    "api/sub-pool.js": {
      "maxDuration": 15
    },
    "api/admin/stats.js": {
      "maxDuration": 15
    },
    "api/admin/users.js": {
      "maxDuration": 15
    },
    "api/admin/user-data.js": {
      "maxDuration": 15
    },
    "api/admin/estimates.js": {
      "maxDuration": 15
    },
    "api/admin/estimate-detail.js": {
      "maxDuration": 15
    },
    "api/admin/embeddings.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
