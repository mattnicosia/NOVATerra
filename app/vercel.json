{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai.js": {
      "maxDuration": 60
    },
    "api/inbound-email.js": {
      "maxDuration": 15
    },
    "api/import-rfp.js": {
      "maxDuration": 30
    },
    "api/retry-parse.js": {
      "maxDuration": 60
    },
    "api/nova-voice.js": {
      "maxDuration": 15
    },
    "api/blob.js": {
      "maxDuration": 30
    },
    "api/ocr.js": {
      "maxDuration": 30
    },
    "api/embed.js": {
      "maxDuration": 15
    },
    "api/vector-search.js": {
      "maxDuration": 15
    },
    "api/seed-embeddings.js": {
      "maxDuration": 120
    },
    "api/send-proposal.js": {
      "maxDuration": 15
    },
    "api/bid-package.js": {
      "maxDuration": 15
    },
    "api/send-bid-invite.js": {
      "maxDuration": 15
    },
    "api/portal.js": {
      "maxDuration": 15
    },
    "api/portal-upload.js": {
      "maxDuration": 15
    },
    "api/proposal-download.js": {
      "maxDuration": 15
    },
    "api/portal-confirm.js": {
      "maxDuration": 30
    },
    "api/parse-proposal.js": {
      "maxDuration": 60
    },
    "api/batch-parse.js": {
      "maxDuration": 120
    },
    "api/scope-gap-narrative.js": {
      "maxDuration": 60
    },
    "api/award-bid.js": {
      "maxDuration": 60
    },
    "api/sub-magic-link.js": {
      "maxDuration": 15
    },
    "api/sub-dashboard.js": {
      "maxDuration": 15
    },
    "api/sub-pool.js": {
      "maxDuration": 15
    },
    "api/admin/stats.js": {
      "maxDuration": 15
    },
    "api/admin/users.js": {
      "maxDuration": 15
    },
    "api/admin/user-data.js": {
      "maxDuration": 15
    },
    "api/admin/estimates.js": {
      "maxDuration": 15
    },
    "api/admin/estimate-detail.js": {
      "maxDuration": 15
    },
    "api/admin/embeddings.js": {
      "maxDuration": 15
    },
    "api/fetch-cloud-files.js": {
      "maxDuration": 60
    },
    "api/cleanup-cloud-files.js": {
      "maxDuration": 15
    },
    "api/send-team-invite.js": {
      "maxDuration": 15
    },
    "api/products/search.js": {
      "maxDuration": 30
    },
    "api/products/categories.js": {
      "maxDuration": 10
    },
    "api/rom-ai.js": {
      "maxDuration": 60
    },
    "api/send-rom-results.js": {
      "maxDuration": 10
    },
    "api/create-living-proposal.js": {
      "maxDuration": 15
    },
    "api/living-proposal.js": {
      "maxDuration": 15
    },
    "api/track-proposal-event.js": {
      "maxDuration": 10
    },
    "api/accept-living-proposal.js": {
      "maxDuration": 15
    },
    "api/generate-rendering.js": {
      "maxDuration": 120
    },
    "api/cron/process-rfps.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-rfps",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/((?!api/|assets/|fonts/).*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
